{
  "manifest_version": 3,
  "name": "IndiaMART Lead Buyer",
  "version": "1.0.0",
  "description": "Automatically buy qualifying leads from IndiaMART buyer requirements",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage",
    "alarms",
    "offscreen"
  ],
  "host_permissions": [
    "https://seller.indiamart.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://seller.indiamart.com/*"],
      "js": ["visibility-override.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://seller.indiamart.com/*"],
      "js": ["content.js"]
    }
  ]
}
